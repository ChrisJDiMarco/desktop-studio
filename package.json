{
  "name": "desktop-studio",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop Studio monorepo — Next.js web app + macOS Electron app",
  "scripts": {
    "dev:web": "pnpm --filter @desktop-studio/web dev",
    "dev:mac": "pnpm --filter @desktop-studio/mac start",
    "build:web": "pnpm --filter @desktop-studio/web build",
    "build:mac": "pnpm --filter @desktop-studio/mac make",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
