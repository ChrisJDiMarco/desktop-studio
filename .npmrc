# Electron Forge requires a hoisted node_modules layout so its native modules
# (and Electron itself) can be located at runtime. This makes pnpm behave more
# like npm/yarn for module resolution. Required workspace-wide because the
# Electron app shares the workspace lockfile with the web app.
node-linker=hoisted

# Skip building native modules during install for packages we don't ship.
# (Leave commented out unless install times become a problem — defaults are fine.)
# side-effects-cache=false
